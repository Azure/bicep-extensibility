{
  "name": "@azure/bicep-extensibility-spec",
  "version": "0.1.0",
  "private": true,
  "description": "TypeSpec definitions for the Bicep Extensibility Provider API",
  "scripts": {
    "build": "tsp compile .",
    "build:yaml": "tsp compile .",
    "format": "tsp format **/*.tsp",
    "watch": "tsp compile . --watch",
    "lint": "tsp compile . --no-emit"
  },
  "dependencies": {
    "@typespec/compiler": "^1.9.0",
    "@typespec/http": "^1.9.1",
    "@typespec/openapi3": "^1.9.0"
  }
}
